#!/usr/bin/env bash
# App-launcher shell daemon control.
#   pibble start     start the persistent daemon (for spawn-at-startup)
#   pibble stop      stop the daemon
#   pibble restart   stop, then start
#   pibble toggle [page]
#                    show/hide the launcher window (for the keybind),
#                    starting the daemon first if it isn't running; with a
#                    page id, opens straight to that page (or switches to
#                    it if another page is open, or closes if it's already
#                    the one showing)
#   pibble replay    re-fire one recent notification; repeated presses step
#                    back through history (see "Replay count" in flyout settings)
#   pibble help      show this message (also what a bare `pibble` does)
repo="$(dirname "$(readlink -f "$0")")"

# Qt can't switch icon themes at runtime, so quickshell reads QS_ICON_THEME
# at startup; pulled from the launcher's persisted settings. Only called
# right before spawning a new daemon, so a toggle against an already-running
# daemon skips the settings read and gsettings round-trip entirely.
export_icon_theme() {
    # quickshell keys persisted state by md5(path to shell.qml), so this
    # stays correct across renames/moves instead of hardcoding the current hash
    shell_id=$(printf '%s' "$repo/shell.qml" | md5sum | cut -d' ' -f1)
    settings="$HOME/.local/state/quickshell/by-shell/$shell_id/settings.json"
    theme=$(sed -n 's/.*"iconTheme": *"\([^"]*\)".*/\1/p' "$settings" 2>/dev/null | head -1)
    # no explicit choice: follow the system (GTK) icon theme, since Qt inside a
    # bare layer-shell session can't detect it and would fall back to hicolor
    [ -z "$theme" ] && theme=$(gsettings get org.gnome.desktop.interface icon-theme 2>/dev/null | tr -d "'")
    [ -n "$theme" ] && export QS_ICON_THEME="$theme"
}

# Native dialogs (e.g. the settings file picker) only route through
# xdg-desktop-portal — showing the user's actual configured picker instead
# of Qt's generic built-in QML fallback — if told to via this platform
# theme; if the plugin isn't installed Qt just keeps the QML fallback, so
# this is safe to set unconditionally.
export_native_dialogs() {
    export QT_QPA_PLATFORMTHEME=xdgdesktopportal
}

# ipc calls fail on ambiguity if duplicate daemons exist; always talk to the
# newest and reap any older duplicates.
ipc() {
    local fn="$1"
    shift
    qs -p "$repo" ipc -n call launcher "$fn" "$@" 2>/dev/null
}
running_pids() {
    pgrep -f "^qs -p $repo\$"
}
reap_duplicates() {
    mapfile -t pids < <(running_pids | sort -n)
    while [ "${#pids[@]}" -gt 1 ]; do
        kill "${pids[0]}" 2>/dev/null
        pids=("${pids[@]:1}")
    done
}
stop_daemon() {
    reap_duplicates
    pids=$(running_pids)
    [ -n "$pids" ] && kill $pids
}

usage() {
    cat <<'USAGE'
pibble — desktop shell daemon control

Usage: pibble <command>

Commands:
  start     start the persistent daemon (for spawn-at-startup)
  stop      stop the daemon
  restart   stop, then start the daemon
  toggle [page]
            show/hide the launcher window, starting the daemon first if
            needed; with a page id, opens/switches straight to that page
            (or closes if it's already the one showing)
  replay    re-fire one recent notification; repeated presses step back
  help      show this message (also what a bare `pibble` does)
USAGE
}

case "$1" in
start)
    # never start a second daemon
    running_pids >/dev/null && exit 0
    export_icon_theme
    export_native_dialogs
    exec qs -p "$repo"
    ;;
stop)
    stop_daemon
    exit 0
    ;;
restart)
    stop_daemon
    for _ in $(seq 1 50); do
        running_pids >/dev/null || break
        sleep 0.1
    done
    export_icon_theme
    export_native_dialogs
    setsid -f qs -p "$repo" >/dev/null 2>&1
    ;;
toggle)
    # $2, if given, is a page id (pibble toggle clips): opens straight onto
    # that page, switches to it if the launcher is already open elsewhere,
    # or closes if it's already the one showing. Always passed through
    # (even empty) since the IPC function takes it as a required argument.
    reap_duplicates
    ipc toggle "$2" && exit 0
    # daemon not running: start it, then retry through the same toggle call
    # so a page argument still lands on the freshly-opened launcher
    export_icon_theme
    export_native_dialogs
    setsid -f qs -p "$repo" >/dev/null 2>&1
    for _ in $(seq 1 50); do
        sleep 0.1
        ipc toggle "$2" && exit 0
    done
    exit 1
    ;;
replay)
    reap_duplicates
    ipc replay && exit 0
    echo "pibble: daemon not running — run 'pibble start' first" >&2
    exit 1
    ;;
help | "")
    usage
    ;;
*)
    echo "pibble: unknown command '$1'" >&2
    usage >&2
    exit 1
    ;;
esac
