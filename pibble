#!/usr/bin/env bash
# App-launcher shell daemon control.
#   pibble start     start the persistent daemon (for spawn-at-startup)
#   pibble stop      stop the daemon
#   pibble restart   stop, then start
#   pibble toggle    show/hide the launcher window (for the keybind),
#                    starting the daemon first if it isn't running
#   pibble replay    re-fire the last few notifications as a stacked burst
#                    (see "Replay count" in flyout settings)
#   pibble help      show this message (also what a bare `pibble` does)
repo="$(dirname "$(readlink -f "$0")")"

# Qt can't switch icon themes at runtime, so quickshell reads QS_ICON_THEME
# at startup; pulled from the launcher's persisted settings. Only called
# right before spawning a new daemon, so a toggle against an already-running
# daemon skips the settings read and gsettings round-trip entirely.
export_icon_theme() {
    # quickshell keys persisted state by md5(path to shell.qml), so this
    # stays correct across renames/moves instead of hardcoding the current hash
    shell_id=$(printf '%s' "$repo/shell.qml" | md5sum | cut -d' ' -f1)
    settings="$HOME/.local/state/quickshell/by-shell/$shell_id/settings.json"
    theme=$(sed -n 's/.*"iconTheme": *"\([^"]*\)".*/\1/p' "$settings" 2>/dev/null | head -1)
    # no explicit choice: follow the system (GTK) icon theme, since Qt inside a
    # bare layer-shell session can't detect it and would fall back to hicolor
    [ -z "$theme" ] && theme=$(gsettings get org.gnome.desktop.interface icon-theme 2>/dev/null | tr -d "'")
    [ -n "$theme" ] && export QS_ICON_THEME="$theme"
}

# ipc calls fail on ambiguity if duplicate daemons exist; always talk to the
# newest and reap any older duplicates.
ipc() {
    qs -p "$repo" ipc -n call launcher "$1" 2>/dev/null
}
running_pids() {
    pgrep -f "^qs -p $repo\$"
}
reap_duplicates() {
    mapfile -t pids < <(running_pids | sort -n)
    while [ "${#pids[@]}" -gt 1 ]; do
        kill "${pids[0]}" 2>/dev/null
        pids=("${pids[@]:1}")
    done
}
stop_daemon() {
    reap_duplicates
    pids=$(running_pids)
    [ -n "$pids" ] && kill $pids
}

usage() {
    cat <<'USAGE'
pibble — desktop shell daemon control

Usage: pibble <command>

Commands:
  start     start the persistent daemon (for spawn-at-startup)
  stop      stop the daemon
  restart   stop, then start the daemon
  toggle    show/hide the launcher window, starting the daemon first if needed
  replay    re-fire the last few notifications as a stacked burst
  help      show this message (also what a bare `pibble` does)
USAGE
}

case "$1" in
start)
    # never start a second daemon
    running_pids >/dev/null && exit 0
    export_icon_theme
    exec qs -p "$repo"
    ;;
stop)
    stop_daemon
    exit 0
    ;;
restart)
    stop_daemon
    for _ in $(seq 1 50); do
        running_pids >/dev/null || break
        sleep 0.1
    done
    export_icon_theme
    setsid -f qs -p "$repo" >/dev/null 2>&1
    ;;
toggle)
    reap_duplicates
    ipc toggle && exit 0
    # daemon not running: start it, then open the launcher
    export_icon_theme
    setsid -f qs -p "$repo" >/dev/null 2>&1
    for _ in $(seq 1 50); do
        sleep 0.1
        ipc open && exit 0
    done
    exit 1
    ;;
replay)
    reap_duplicates
    ipc replay && exit 0
    echo "pibble: daemon not running — run 'pibble start' first" >&2
    exit 1
    ;;
help | "")
    usage
    ;;
*)
    echo "pibble: unknown command '$1'" >&2
    usage >&2
    exit 1
    ;;
esac
